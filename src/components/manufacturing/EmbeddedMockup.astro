---
// src/components/manufacturing/EmbeddedMockup.astro
import MockupGenerator from '../MockupGenerator';

interface Props {
  formatName: string;
}

const { formatName } = Astro.props;

// Robust mapping from page formatName to mockup preset slugs
const getPresetSlug = (name: string) => {
  const n = name.toLowerCase();
  if (n.includes('gummy')) return 'gummies';
  if (n.includes('capsule')) return 'capsules';
  if (n.includes('powder')) return 'powders';
  if (n.includes('honey gel')) return 'gel';
  if (n.includes('sachet') || n.includes('honey spoon') || n.includes('spoon')) return 'spoons';
  if (n.includes('soft gel')) return 'soft-gels';
  return 'gummies'; // Default fallback
};

const initialFormat = getPresetSlug(formatName);
---

<section class="audience-section">
  <div class="container">
    <div class="section-header" data-reveal>
      <span class="section-eyebrow">Visual Experience</span>
      <h2 id="mockup-heading">Visualize Your {formatName} Product</h2>
      <p class="section-subhead">See what your branding will look like on our premium, retail-ready formats instantly.</p>
    </div>
    
    <div class="mockup-embed-wrapper" data-reveal style="border-radius: var(--radius-lg); overflow: hidden; background: transparent;">
      <MockupGenerator 
        client:visible 
        initialFormat={initialFormat} 
      />
    </div>
  </div>
</section>

<script>
  window.addEventListener('mockup:formatChange', (e: Event) => {
    const heading = document.getElementById('mockup-heading');
    if (heading) {
      heading.textContent = `Visualize Your ${(e as CustomEvent).detail.label} Product`;
    }
  });
</script>
